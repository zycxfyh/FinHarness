{
  "schema": "finharness.fuzz_corpus.v1",
  "description": "Deterministic governance-boundary fuzz cases. No secrets, credentials, live provider calls, or autonomous execution.",
  "cases": [
    {
      "id": "security_surface_current_boundaries",
      "target": "security_surface",
      "paths": [
        "src/finharness/authorization.py",
        "src/finharness/restricted_symbols.py",
        "docs/security/finharness-threat-model.md",
        "experiments/archive/live_trading_legacy/okx/okx_cli.py",
        ".github/workflows/security.yml"
      ]
    },
    {
      "id": "security_surface_doc_only",
      "target": "security_surface",
      "paths": [
        "docs/ordinary.md"
      ]
    },
    {
      "id": "research_assets_known_and_unknown",
      "target": "research_assets",
      "asset_ids": [
        "trend_following_v0",
        "no_lookahead_validation_v0",
        "unknown_asset",
        "live_write_enable"
      ],
      "layer": "L5"
    },
    {
      "id": "research_assets_path_like_ids",
      "target": "research_assets",
      "asset_ids": [
        "../secret",
        ".env",
        "OKX-LIVE-WRITE"
      ],
      "layer": "L4"
    }
  ]
}
