# Local non-secret configuration template.
#
# Copy only the values you need into a private ignored env file.
# Never commit real secrets.

# Optional State Core / receipt locations.
FINHARNESS_STATE_CORE_DB_PATH=
FINHARNESS_RECEIPT_ROOT=
FINHARNESS_BACKUP_ROOT=

# Optional runtime behavior.
FINHARNESS_LOG_JSON=true
FINHARNESS_AUTHORIZATION_REGISTRY_PATH=
FINHARNESS_RESTRICTED_SYMBOLS_PATH=

# Optional OpenAI-compatible model review. Keep the key out of git and logs.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
FINHARNESS_AGENT_MODEL=deepseek-v4-pro

# Broker credential templates from archived live-trading experiments are not
# mainline configuration. Do not reintroduce broker env vars without a new
# proposal/ADR, explicit gates, receipts, and current-doc updates.
